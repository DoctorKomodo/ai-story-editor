{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          },
          {
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-edit-typecheck.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-edit-typecheck.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  }
}
