# ---- Backend ----

# PostgreSQL connection string used by Prisma
DATABASE_URL=postgresql://storyeditor:storyeditor@postgres:5432/storyeditor

# Public URL of the frontend, used for CORS origin allowlist + the CSRF
# Origin/Referer check on ALL /api routes (POST/PUT/PATCH/DELETE). Must be
# the public HTTPS origin in production. Accepts a comma-separated list to
# permit multiple dev origins (e.g. localhost + the LAN IP of the dev box).
# Production should set a single value.
FRONTEND_URL=http://localhost:3000

# Max number of concurrent in-memory sessions (default 10000).
# Raise if you see "evicting a live session under cap pressure" in logs.
# SESSION_STORE_MAX=10000

# Reverse-proxy hop count for Express trust-proxy (default 1).
# Must equal the actual number of trusted proxy hops in your topology.
# Set to 0 if Inkwell is exposed directly to the internet (no proxy).
# NEVER use a value that trusts all hops (e.g. 'true') — that lets clients
# spoof X-Forwarded-For headers and defeat rate limits.
# TRUST_PROXY_HOPS=1

# Port the backend Express server listens on
PORT=4000

# ---- Frontend ----

# Public URL of the backend API, used by the Vite frontend at build/runtime
VITE_API_URL=http://localhost:4000

# ---- Deployment (published images) ----

# Release image tag to run from GHCR via docker-compose.release.yml. Defaults
# to `latest`, so `docker compose pull && docker compose up -d` always grabs
# the newest release. Pin a specific version for reproducible deploys:
#   INKWELL_VERSION=0.2.0
# (The app version shown in the UI footer is baked into the published frontend
# image at build time — it is not an operator-set runtime variable.)
# INKWELL_VERSION=latest
