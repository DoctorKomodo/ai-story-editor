# ---- Backend ----

# PostgreSQL connection string used by Prisma
DATABASE_URL=postgresql://storyeditor:storyeditor@postgres:5432/storyeditor

# Secret used to sign JWT access tokens (15 minute lifetime)
JWT_SECRET=change-me-to-a-long-random-string

# Secret used to sign refresh tokens (7 day lifetime, stored in httpOnly cookie)
REFRESH_TOKEN_SECRET=change-me-to-a-different-long-random-string

# Public URL of the frontend, used for CORS origin allowlist + the CSRF
# Origin/Referer check on cookie-authed /api/auth routes. Accepts a
# comma-separated list to permit multiple dev origins (e.g. localhost +
# the LAN IP of the dev box). Production should set a single value.
FRONTEND_URL=http://localhost:3000

# Port the backend Express server listens on
PORT=4000

# ---- Frontend ----

# Public URL of the backend API, used by the Vite frontend at build/runtime
VITE_API_URL=http://localhost:4000

# ---- Deployment (published images) ----

# Release image tag to run from GHCR via docker-compose.release.yml. Defaults
# to `latest`, so `docker compose pull && docker compose up -d` always grabs
# the newest release. Pin a specific version for reproducible deploys:
#   INKWELL_VERSION=0.2.0
# (The app version shown in the UI footer is baked into the published frontend
# image at build time — it is not an operator-set runtime variable.)
# INKWELL_VERSION=latest
