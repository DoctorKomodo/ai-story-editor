# ---- Backend ----

# PostgreSQL connection string used by Prisma
DATABASE_URL=postgresql://storyeditor:storyeditor@postgres:5432/storyeditor

# Secret used to sign JWT access tokens (15 minute lifetime)
JWT_SECRET=change-me-to-a-long-random-string

# Secret used to sign refresh tokens (7 day lifetime, stored in httpOnly cookie)
REFRESH_TOKEN_SECRET=change-me-to-a-different-long-random-string

# AES-256-GCM key that wraps stored BYOK Venice API keys. Must decode from
# base64 to exactly 32 bytes. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
# Losing this key loses stored Venice keys (users must re-enter once); it does
# NOT render narrative content unrecoverable — content DEKs are derived from
# user credentials (see docs/encryption.md).
APP_ENCRYPTION_KEY=change-me-to-a-base64-encoded-32-byte-key

# Venice.ai API key. Backend only — never expose to the frontend build.
VENICE_API_KEY=your-venice-api-key-here

# Public URL of the frontend, used for CORS origin allowlist
FRONTEND_URL=http://localhost:3000

# Port the backend Express server listens on
PORT=4000

# ---- Frontend ----

# Public URL of the backend API, used by the Vite frontend at build/runtime
VITE_API_URL=http://localhost:4000
