// Story Editor — Prisma schema.
// All models own createdAt/updatedAt. Foreign keys are indexed. Cascades are
// declared on the relation, never in application code (see CLAUDE.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String   @id @default(cuid())
  email                     String?  @unique
  username                  String   @unique
  name                      String?
  passwordHash              String
  settingsJson              Json?
  veniceApiKeyEnc           String?
  veniceApiKeyIv            String?
  veniceApiKeyAuthTag       String?
  veniceEndpoint            String?
  // Envelope-encryption wrap columns ([E3]). Both wraps protect the SAME
  // 32-byte random DEK. Nullable to permit a migration window where users
  // predate [E3] — their wraps are populated on first login after deploy,
  // when the password is available. See docs/encryption.md.
  contentDekPasswordEnc     String?
  contentDekPasswordIv      String?
  contentDekPasswordAuthTag String?
  contentDekPasswordSalt    String?
  contentDekRecoveryEnc     String?
  contentDekRecoveryIv      String?
  contentDekRecoveryAuthTag String?
  contentDekRecoverySalt    String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  stories Story[]
}

model Story {
  id                              String   @id @default(cuid())
  genre                           String?
  targetWords                     Int?
  // [E4] ciphertext triples — now the SOLE source of truth for narrative
  // fields (title, synopsis, worldNotes). Populated by the repo layer
  // ([E9]) on write. Plaintext siblings were dropped in [E11].
  // [X29] Story.systemPrompt removed; user-level overrides live in
  // User.settingsJson.prompts.
  // `genre`, `targetWords`, `userId`, timestamps remain plaintext.
  titleCiphertext                 String?
  titleIv                         String?
  titleAuthTag                    String?
  synopsisCiphertext              String?
  synopsisIv                      String?
  synopsisAuthTag                 String?
  worldNotesCiphertext            String?
  worldNotesIv                    String?
  worldNotesAuthTag               String?
  includePreviousChaptersInPrompt Boolean  @default(true)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  chapters     Chapter[]
  characters   Character[]
  outlineItems OutlineItem[]

  @@index([userId])
}

model Chapter {
  id                    String    @id @default(cuid())
  orderIndex            Int
  wordCount             Int       @default(0)
  // [E5] ciphertext triples — now the SOLE source of truth for narrative
  // fields. `bodyCiphertext` encodes the serialised TipTap JSON tree.
  // `wordCount` is derived from the tree at save time (before encryption) so
  // UI progress calcs keep working without decryption. Plaintext `title`,
  // `content`, `bodyJson` were dropped in [E11].
  titleCiphertext       String?
  titleIv               String?
  titleAuthTag          String?
  bodyCiphertext        String?
  bodyIv                String?
  bodyAuthTag           String?
  summaryJsonCiphertext String?
  summaryJsonIv         String?
  summaryJsonAuthTag    String?
  summaryJsonUpdatedAt  DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  storyId String
  story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  chats   Chat[]

  activeDraftId String? @unique
  activeDraft   Draft?  @relation("ActiveDraft", fields: [activeDraftId], references: [id], onDelete: SetNull)
  drafts        Draft[] @relation("ChapterDrafts")

  // [D16] Uniqueness at the DB level is the only reliable guard against the
  // aggregate(_max)+insert race in the POST handler; a unique constraint also
  // creates the btree index Postgres needs for `ORDER BY orderIndex ASC`, so
  // the separate `@@index([storyId, orderIndex])` becomes redundant.
  @@unique([storyId, orderIndex])
  @@index([storyId])
}

model Draft {
  id                    String    @id @default(cuid())
  // [9wk.2] body + summary + wordCount relocated off Chapter (expand phase —
  // Chapter still carries its copies until step 5's contract drop). Ciphertext
  // triples are the SOLE source of truth, written by draft.repo via the
  // standard envelope-encryption helpers. `wordCount` is plaintext, derived
  // from the body before encryption at the route layer (step 4).
  bodyCiphertext        String?
  bodyIv                String?
  bodyAuthTag           String?
  summaryJsonCiphertext String?
  summaryJsonIv         String?
  summaryJsonAuthTag    String?
  summaryJsonUpdatedAt  DateTime?
  wordCount             Int       @default(0)
  // Custom draft name ("darker take"). NULL ⇒ frontend renders a positional
  // label. Encrypted because a label can leak plot.
  labelCiphertext       String?
  labelIv               String?
  labelAuthTag          String?
  orderIndex            Int
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  chapterId String
  chapter   Chapter @relation("ChapterDrafts", fields: [chapterId], references: [id], onDelete: Cascade)
  // Back-side of Chapter.activeDraft (the active-pointer relation).
  activeForChapter Chapter? @relation("ActiveDraft")
  chats            Chat[]  @relation("DraftChats")

  @@unique([chapterId, orderIndex])
  @@index([chapterId])
}

model Character {
  id                      String   @id @default(cuid())
  initial                 String?
  color                   String?
  orderIndex              Int
  // [E6] ciphertext triples for every narrative field — now the SOLE source
  // of truth. `color`, `initial`, `storyId`, timestamps remain plaintext (UI
  // hints + structural fields). Plaintext narrative siblings were dropped in
  // [E11].
  nameCiphertext          String?
  nameIv                  String?
  nameAuthTag             String?
  roleCiphertext          String?
  roleIv                  String?
  roleAuthTag             String?
  ageCiphertext           String?
  ageIv                   String?
  ageAuthTag              String?
  appearanceCiphertext    String?
  appearanceIv            String?
  appearanceAuthTag       String?
  voiceCiphertext         String?
  voiceIv                 String?
  voiceAuthTag            String?
  arcCiphertext           String?
  arcIv                   String?
  arcAuthTag              String?
  relationshipsCiphertext String?
  relationshipsIv         String?
  relationshipsAuthTag    String?
  personalityCiphertext   String?
  personalityIv           String?
  personalityAuthTag      String?
  backstoryCiphertext     String?
  backstoryIv             String?
  backstoryAuthTag        String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  storyId String
  story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)

  // [cast-ui] Same race guard as Chapter — unique constraint prevents
  // aggregate(_max)+insert race in POST handler and provides the btree index
  // Postgres needs for `ORDER BY orderIndex ASC`.
  @@unique([storyId, orderIndex])
  @@index([storyId])
}

model OutlineItem {
  id              String   @id @default(cuid())
  order           Int
  status          String
  // [E7] ciphertext triples — now the SOLE source of truth for narrative
  // fields (title, sub). `order`, `status`, `storyId`, timestamps stay
  // plaintext so Postgres can sort/filter and the UI can render status chips
  // without decryption. Plaintext narrative siblings were dropped in [E11].
  titleCiphertext String?
  titleIv         String?
  titleAuthTag    String?
  subCiphertext   String?
  subIv           String?
  subAuthTag      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  storyId String
  story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)

  // [D16] See Chapter — same race, same fix.
  @@unique([storyId, order])
  @@index([storyId])
}

model Chat {
  id              String   @id @default(cuid())
  kind            String   @default("ask") // "ask" | "scene"
  // [E8] ciphertext triple for the chat title — now the SOLE source of truth.
  // `chapterId` + timestamps remain plaintext (FK + timeline ordering).
  // Plaintext `title` was dropped in [E11].
  titleCiphertext String?
  titleIv         String?
  titleAuthTag    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  // story-editor-loj: bumped on every child-message create. SessionPicker
  // reads this for the "X ago" label and the dropdown order. Distinct from
  // updatedAt, which only fires on Chat-row metadata changes (e.g. rename).
  lastActivityAt  DateTime @default(now())

  chapterId String
  draftId   String?
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  draft     Draft?  @relation("DraftChats", fields: [draftId], references: [id], onDelete: Cascade)

  messages Message[]

  @@index([chapterId])
  @@index([chapterId, kind])
  // story-editor-loj: index supports the findManyForChapter ORDER BY.
  @@index([chapterId, lastActivityAt])
}

model Message {
  id                       String   @id @default(cuid())
  role                     String
  model                    String?
  tokens                   Int?
  latencyMs                Int?
  // [E8] ciphertext triples — now the SOLE source of truth. `role`, `model`,
  // `tokens`, `latencyMs`, timestamps remain plaintext — needed for the chat
  // header meta row + regeneration flows. Plaintext `contentJson` +
  // `attachmentJson` were dropped in [E11]. `content*` encrypts a plain
  // string; `attachmentJson*` and `citationsJson*` encrypt serialised JSON
  // payloads.
  contentCiphertext        String?
  contentIv                String?
  contentAuthTag           String?
  attachmentJsonCiphertext String?
  attachmentJsonIv         String?
  attachmentJsonAuthTag    String?
  // [V26] Encrypted-at-rest citations for assistant turns backed by Venice
  // web search. Stored as serialised JSON (`Citation[]`) via the repo layer.
  // Only populated when the turn produced ≥1 valid citation; otherwise all
  // three columns are NULL (see docs/venice-integration.md § Citations).
  citationsJsonCiphertext  String?
  citationsJsonIv          String?
  citationsJsonAuthTag     String?
  createdAt                DateTime @default(now())
  // Null = never edited. Set explicitly by the edit path (message.repo.update),
  // never by create — deliberately not @updatedAt, so "edited?" is unambiguous.
  // See docs/superpowers/specs/2026-06-14-chat-message-edit-resend-design.md.
  updatedAt                DateTime?

  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([chatId, createdAt])
}

