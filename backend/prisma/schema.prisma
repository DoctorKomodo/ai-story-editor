// Story Editor — Prisma schema.
// All models own createdAt/updatedAt. Foreign keys are indexed. Cascades are
// declared on the relation, never in application code (see CLAUDE.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String         @id @default(cuid())
  email                 String?        @unique
  username              String         @unique
  name                  String?
  passwordHash          String
  settingsJson          Json?
  veniceApiKeyEnc       String?
  veniceApiKeyIv        String?
  veniceApiKeyAuthTag   String?
  veniceEndpoint        String?
  // Envelope-encryption wrap columns ([E3]). Both wraps protect the SAME
  // 32-byte random DEK. Nullable to permit a migration window where users
  // predate [E3] — their wraps are populated on first login after deploy,
  // when the password is available. See docs/encryption.md.
  contentDekPasswordEnc     String?
  contentDekPasswordIv      String?
  contentDekPasswordAuthTag String?
  contentDekPasswordSalt    String?
  contentDekRecoveryEnc     String?
  contentDekRecoveryIv      String?
  contentDekRecoveryAuthTag String?
  contentDekRecoverySalt    String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  stories       Story[]
  refreshTokens RefreshToken[]
  sessions      Session[]
}

// Session rows for Option B DEK-survival (see docs/encryption.md). The DEK
// itself is NOT stored here — only the in-process map holds it. The row
// exists so a cold replica or restart can detect "session expired" and force
// re-authentication instead of silently 500-ing.
model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Story {
  id           String        @id @default(cuid())
  title        String
  synopsis     String?
  genre        String?
  worldNotes   String?
  targetWords  Int?
  systemPrompt String?
  // [E4] ciphertext triples. Populated by the repo layer ([E9]) on write.
  // Plaintext columns above stay during the dual-write window and are dropped
  // in [E11]. `genre`, `targetWords`, `userId`, timestamps remain plaintext.
  titleCiphertext         String?
  titleIv                 String?
  titleAuthTag            String?
  synopsisCiphertext      String?
  synopsisIv              String?
  synopsisAuthTag         String?
  worldNotesCiphertext    String?
  worldNotesIv            String?
  worldNotesAuthTag       String?
  systemPromptCiphertext  String?
  systemPromptIv          String?
  systemPromptAuthTag     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  chapters     Chapter[]
  characters   Character[]
  outlineItems OutlineItem[]

  @@index([userId])
}

model Chapter {
  id          String   @id @default(cuid())
  title       String
  content     String   @default("")
  bodyJson    Json?
  status      String   @default("draft")
  orderIndex  Int
  wordCount   Int      @default(0)
  // [E5] ciphertext triples. `bodyCiphertext` encodes the serialised TipTap
  // JSON tree. `wordCount` is derived from the tree at save time (before
  // encryption) so UI progress calcs keep working without decryption.
  // Plaintext `content` + `bodyJson` remain during the dual-write window
  // and are dropped in [E11].
  titleCiphertext String?
  titleIv         String?
  titleAuthTag    String?
  bodyCiphertext  String?
  bodyIv          String?
  bodyAuthTag     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  chats       Chat[]

  @@index([storyId])
  @@index([storyId, orderIndex])
}

model Character {
  id                  String   @id @default(cuid())
  name                String
  role                String?
  age                 String?
  appearance          String?
  voice               String?
  arc                 String?
  initial             String?
  color               String?
  physicalDescription String?
  personality         String?
  backstory           String?
  notes               String?
  // [E6] ciphertext triples for every narrative field. `color`, `initial`,
  // `storyId`, timestamps remain plaintext (UI hints + structural fields).
  nameCiphertext                String?
  nameIv                        String?
  nameAuthTag                   String?
  roleCiphertext                String?
  roleIv                        String?
  roleAuthTag                   String?
  ageCiphertext                 String?
  ageIv                         String?
  ageAuthTag                    String?
  appearanceCiphertext          String?
  appearanceIv                  String?
  appearanceAuthTag             String?
  voiceCiphertext               String?
  voiceIv                       String?
  voiceAuthTag                  String?
  arcCiphertext                 String?
  arcIv                         String?
  arcAuthTag                    String?
  physicalDescriptionCiphertext String?
  physicalDescriptionIv         String?
  physicalDescriptionAuthTag    String?
  personalityCiphertext         String?
  personalityIv                 String?
  personalityAuthTag            String?
  backstoryCiphertext           String?
  backstoryIv                   String?
  backstoryAuthTag              String?
  notesCiphertext               String?
  notesIv                       String?
  notesAuthTag                  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  storyId             String
  story               Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
}

model OutlineItem {
  id        String   @id @default(cuid())
  order     Int
  title     String
  sub       String?
  status    String
  // [E7] ciphertext triples. `order`, `status`, `storyId`, timestamps stay
  // plaintext so Postgres can sort/filter and the UI can render status chips
  // without decryption.
  titleCiphertext String?
  titleIv         String?
  titleAuthTag    String?
  subCiphertext   String?
  subIv           String?
  subAuthTag      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@index([storyId, order])
}

model Chat {
  id        String   @id @default(cuid())
  title     String?
  // [E8] ciphertext triple for the chat title. `chapterId` + timestamps
  // remain plaintext (FK + timeline ordering).
  titleCiphertext String?
  titleIv         String?
  titleAuthTag    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  messages  Message[]

  @@index([chapterId])
}

model Message {
  id             String   @id @default(cuid())
  role           String
  contentJson    Json
  attachmentJson Json?
  model          String?
  tokens         Int?
  latencyMs      Int?
  // [E8] ciphertext triples for the JSON payloads (encrypted as serialised
  // JSON strings). `role`, `model`, `tokens`, `latencyMs`, timestamps remain
  // plaintext — needed for the chat header meta row + regeneration flows.
  contentJsonCiphertext    String?
  contentJsonIv            String?
  contentJsonAuthTag       String?
  attachmentJsonCiphertext String?
  attachmentJsonIv         String?
  attachmentJsonAuthTag    String?
  createdAt      DateTime @default(now())

  chatId         String
  chat           Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([chatId, createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
