# L-series live Venice testing (opt-in, DEV-ONLY).
#
# Never set these in production. No production code path reads them — the
# probe CLI and the tests/live/** suite are the only consumers. Use a
# SPENDING-CAPPED Venice API key for these, not your primary BYOK key.
#
# To activate: copy this file to backend/.env.live (which is gitignored)
# and fill in values. Then run:
#   cd backend && npm run venice:probe -- --models
#   cd backend && npm run test:live

LIVE_VENICE_API_KEY=
# Optional — omit to use Venice's default https://api.venice.ai/api/v1
LIVE_VENICE_ENDPOINT=
# Model id to use for the completion tests. Pick a cheap text model.
LIVE_VENICE_MODEL=llama-3.3-70b
