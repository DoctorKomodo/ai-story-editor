{
  "name": "story-editor-backend",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "NODE_OPTIONS=--conditions=source ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "vitest run",
    "test:backend": "vitest",
    "db:test:reset": "bash ../scripts/db-test-reset.sh",
    "test:live": "bash -c 'OUT=$(vitest run --config vitest.live.config.ts \"$@\" 2>&1); CODE=$?; echo \"$OUT\"; exit $CODE' --",
    "venice:probe": "ts-node scripts/venice-probe.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "openai": "^6.36.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "story-editor-shared": "*",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
