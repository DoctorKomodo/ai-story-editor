{
  "name": "story-editor-backend",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "prisma generate && tsx watch src/index.ts",
    "test": "vitest run",
    "test:backend": "vitest",
    "db:test:reset": "bash ../scripts/db-test-reset.sh",
    "test:live": "bash -c 'OUT=$(vitest run --config vitest.live.config.ts \"$@\" 2>&1); CODE=$?; echo \"$OUT\"; exit $CODE' --",
    "test:migration-squash": "vitest run --config vitest.squash.config.ts",
    "venice:probe": "tsx scripts/venice-probe.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.45.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "morgan": "^1.11.0",
    "openai": "^6.48.0",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "story-editor-shared": "*",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  }
}
