# Test-database env for local backend test runs. Copy to `.env.test` at the
# repo root (gitignored):
#
#   cp .env.test.example .env.test
#
# scripts/db-test-reset.sh hard-fails without .env.test, and the backend
# vitest globalSetup runs that script before every local (non-CI) suite run —
# so `make test` / `npm run test:backend` need this file to exist. CI skips
# the script and injects DATABASE_URL directly.
#
# Must point at a THROWAWAY test database — the reset script DROPs and
# recreates it on every run. Never point this at the dev database.
# This URL is the TEMPLATE database: the suite migrates it once, then clones
# it per worker (storyeditor_test_w1..wN — see backend/tests/worker-db.ts,
# the pinned default is storyeditor_test on localhost:5432). If you change
# it, also export TEST_DATABASE_URL with the same value when running tests.
DATABASE_URL=postgresql://storyeditor:storyeditor@localhost:5432/storyeditor_test

# Name of the running postgres container the reset script `docker exec`s into.
# Default matches the `make dev` compose stack.
# POSTGRES_CONTAINER=story-editor-postgres-1

# Switches argon2id to deliberately weak parameters so the backend test suite
# doesn't pay production-cost KDF derivations on every register/login
# (backend/src/services/argon2.config.ts). Safe because it is double-gated —
# it only takes effect when NODE_ENV=test — and the backend refuses to boot
# if it is set with NODE_ENV=production. This file is its ONLY legitimate
# home: never put it in .env or any real deployment env. The backend vitest
# config (backend/vitest.config.ts `test.env`) injects it for local and CI
# runs, so this entry documents the flag rather than activating it.
TEST_FAST_ARGON2=1
